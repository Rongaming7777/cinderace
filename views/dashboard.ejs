        <div class="main-panel">
          <div class="content-wrapper">
            <div class="row"> 
<% products.forEach(item => { %>
<div class="shopitemframe">
                    <div class="shopitemframeTitle">
                        <%= item.title %>
                    </div>

                    <div class="shopitemframeImage">
                        <img src="<%= item.image %>"
                            alt="<%= item.title %>">
                    </div>

                    <div class="shopitemframeText">
                      <%= item.description %>
                    </div>
                    <div class="shopitemframeAuthor">
                        @<%= item.author %>
                    </div>
                    <div class="shopitemframePrise">
                        $<%= item.price %>
                    </div>
                   <% if (item.instock >= item.min) { %>
          <button class="btn btn-warning btn-rounded btn-fw buy" onclick="openPopup('popup<%= item.id %>')">Buy</button>
        <% } else { %>
          <button class="btn btn-inverse-danger btn-rounded btn-fw" onclick"basic">Out Of Stock</button>
        <% } %>
      </div>
      <div id="popup<%= item.id %>" class="popup">
    <div class="modal-box">
      <span class="fas fa-times" onclick="closePopup('popup<%= item.id %>')"></span>
      <div class="mdi mdi-cart-plus icon1"></div>
         <header> <%= item.title %></header>
         <form action="/shop/<%=user.id%>/post/shop" method="post">
            <price> Quantity: </price>
            <div class="mdi mdi-numeric icon2"></div>
            <input id="quan_<%= item.id %>" oninput="quanmultiply_<%= item.id %>()" class="totalp" type="number" value="<%= item.min %>" required placeholder="1-<%= item.instock %>" max="<%= item.instock %>" min="<%= item.min %>" oninvalid="this.setCustomValidity('Only <%= item.instock %> In Stock')"
       oninput="this.setCustomValidity('')"/>
       <price> Price: </price><div class="mdi mdi-cash icon2"></div><input id="price_<%= item.id %>" class="totalp" type="text" value="<%= item.price %>" readonly/><br>
       <price> Total Price: </price><div class="mdi mdi-cash-multiple icon2"></div><input id="totalprice_<%= item.id %>" type="text" value="<%= item.price %>" readonly/><br>
            <button>Buy Now</button>
         </form>
    </div>
			</div>
<script>
function quanmultiply_<%= item.id %>() {
     var quant_<%= item.id %> = document.getElementById('quan_<%= item.id %>').value;
      var price_<%= item.id %> = document.getElementById('price_<%= item.id %>').value;
	    var min_<%= item.id %> = <%= item.min %>
      var result1_<%= item.id %> = price_<%= item.id %> / min_<%= item.id %>;
	    var result_<%= item.id %> = result1_<%= item.id %> * quant_<%= item.id %> 
      document.getElementById('totalprice_<%= item.id %>').value = result_<%= item.id %>;
      
				}
</script>
	
      <% });%>


				
